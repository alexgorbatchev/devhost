{
  "name": "localhost-domains",
  "private": true,
  "type": "module",
  "workspaces": [
    "devhost",
    "test"
  ],
  "scripts": {
    "check": "./scripts/check.sh",
    "devhost": "bun run ./devhost/src/main.ts",
    "policy:fix:semantic": "bun run typescript-ai-policy-fix-semantic -- .",
    "storybook:install-browser": "cd devhost && bun x playwright install chromium",
    "test:hello": "cd test && bun run dev",
    "caddy:download": "./scripts/download-caddy.sh"
  },
  "devDependencies": {
    "@alexgorbatchev/typescript-ai-policy": "^1.0.3",
    "@typescript/native-preview": "^7.0.0-dev.20260331.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  }
}
