{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bun --bun oxfmt --check . && bun --bun oxlint . && bun run --cwd packages/devhost check && bun run --cwd packages/www check",
    "deploy:www": "bun ./scripts/deployWwwRailway.ts",
    "dev": "bun run --cwd packages/www devhost",
    "fix": "bun --bun oxfmt --write ."
  },
  "devDependencies": {
    "@alexgorbatchev/typescript-ai-policy": "^3.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0"
  }
}
